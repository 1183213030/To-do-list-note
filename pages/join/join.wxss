.join-card {
  background: #ffffff;
  margin: 48rpx 24rpx;
  border-radius: 28rpx;
  padding: 64rpx 32rpx;
  text-align: center;
}

.join-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.join-title {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.join-list-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #111111;
  margin-bottom: 48rpx;
}

.join-info {
  background: #f5f5f7;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 48rpx;
}

.join-info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.join-info-label {
  font-size: 28rpx;
  color: #666666;
}

.join-info-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #111111;
}

.already-member {
  font-size: 28rpx;
  color: #34c759;
  margin-bottom: 24rpx;
}

.join-button-container {
  width: 100%;
}

.join-button-container button {
  width: 100%;
}
