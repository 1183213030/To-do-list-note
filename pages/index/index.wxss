.header {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.logo {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 12rpx;
}

.welcome {
  font-size: 28rpx;
  color: var(--text-light);
}

.input-card {
  margin-bottom: 48rpx;
}

.input-label {
  font-size: 28rpx;
  color: var(--text-light);
  margin-bottom: 16rpx;
}

.room-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid var(--gray);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 40rpx;
  text-align: center;
  letter-spacing: 8rpx;
  font-weight: 600;
}

.button-group {
  display: flex;
  gap: 24rpx;
  margin-top: 24rpx;
}

.button-group button {
  flex: 1;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-light);
  margin: 32rpx 0 16rpx;
  padding: 0 32rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.room-list {
  padding: 0;
}

.room-card {
  margin: 0 32rpx 24rpx;
  padding: 32rpx;
}

.room-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.room-code {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text);
}

.room-lock {
  font-size: 32rpx;
}

.room-stats {
  font-size: 28rpx;
  color: var(--text);
  margin-bottom: 12rpx;
}

.room-members {
  font-size: 24rpx;
  color: var(--text-light);
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 12rpx;
}
