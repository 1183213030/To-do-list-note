.tips {
  background: #fff3cd;
  border-left: 4rpx solid #ffc107;
  padding: 24rpx;
  margin: 24rpx;
  border-radius: 16rpx;
}

.tips-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #856404;
  margin-bottom: 12rpx;
}

.tips-content {
  font-size: 28rpx;
  color: #856404;
  line-height: 1.6;
}

.form {
  background: #ffffff;
  margin: 24rpx;
  border-radius: 28rpx;
  padding: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.form-textarea {
  background: #f5f5f7;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 24rpx;
  color: #111111;
  min-height: 400rpx;
  width: 100%;
  box-sizing: border-box;
  font-family: Monaco, Consolas, monospace;
}

.button-group {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
}

.button-group button {
  flex: 1;
}
