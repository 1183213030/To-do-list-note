.user-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  margin: 24rpx;
  border-radius: 28rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  color: #ffffff;
}

.user-avatar {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.user-id {
  font-size: 28rpx;
  opacity: 0.8;
  margin-bottom: 8rpx;
}

.user-mode {
  font-size: 24rpx;
  opacity: 0.7;
}

.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #007aff;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 28rpx;
  color: #666666;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eeeeee;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #eeeeee;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f5f5f7;
}

.menu-label {
  font-size: 32rpx;
  color: #111111;
}

.menu-arrow {
  font-size: 48rpx;
  color: #c7c7cc;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #666666;
  padding: 32rpx 24rpx 12rpx;
  text-transform: uppercase;
}
