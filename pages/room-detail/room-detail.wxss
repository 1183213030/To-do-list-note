.loading {
  text-align: center;
  padding: 120rpx 0;
  color: var(--text-light);
}

.room-header {
  margin-bottom: 24rpx;
}

.room-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.room-code-badge {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary);
}

.room-lock {
  font-size: 28rpx;
}

.room-stats-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 28rpx;
  color: var(--text);
  margin-bottom: 12rpx;
}

.divider {
  color: var(--gray);
}

.room-members-row {
  font-size: 24rpx;
  color: var(--text-light);
  display: flex;
  align-items: center;
}

.label {
  margin-right: 8rpx;
}

.action-row {
  margin-top: 24rpx;
}

.btn-block {
  width: 100%;
}

.input-section {
  margin-bottom: 24rpx;
}

.todo-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 32rpx;
  line-height: 1.5;
  padding: 0;
}

.input-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.char-count {
  font-size: 24rpx;
  color: var(--text-light);
}

.btn-small {
  padding: 12rpx 32rpx;
  height: auto;
  line-height: 1.5;
  font-size: 28rpx;
}

.todo-section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-light);
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.todo-list {
  padding: 0;
}

.todo-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  margin: 0 32rpx 16rpx;
}

.todo-item.pinned {
  background: linear-gradient(135deg, #FFF9E6 0%, #FFFFFF 100%);
  border-left: 4rpx solid #FFD700;
}

.todo-item.completed {
  opacity: 0.6;
}

.todo-left {
  flex: 1;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid var(--gray);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 24rpx;
  transition: all 0.3s ease;
}

.checkbox.checked {
  background: var(--primary);
  border-color: var(--primary);
  color: white;
}

.todo-content {
  flex: 1;
  padding-top: 4rpx;
}

.todo-text {
  font-size: 32rpx;
  color: var(--text);
  line-height: 1.5;
  word-break: break-all;
}

.completed .todo-text {
  text-decoration: line-through;
  color: var(--text-light);
}

.todo-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-light);
}

.todo-actions {
  display: flex;
  gap: 16rpx;
  margin-left: 16rpx;
}

.action-btn {
  font-size: 32rpx;
  padding: 8rpx;
  opacity: 0.6;
  transition: opacity 0.3s ease;
}

.action-btn:active {
  opacity: 1;
}
