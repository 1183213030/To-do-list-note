.list-header {
  background: #ffffff;
  padding: 24rpx;
  margin: 0 24rpx 24rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.list-header-info {
  flex: 1;
}

.list-header-members {
  font-size: 28rpx;
  color: #666666;
}

.share-btn {
  background: #007aff;
  color: #ffffff;
  border-radius: 40rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  border: none;
  line-height: 1.4;
}

.section {
  margin-bottom: 24rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #666666;
  padding: 0 24rpx 12rpx;
  text-transform: uppercase;
}

.task-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #eeeeee;
}

.task-item:last-child {
  border-bottom: none;
}

.task-item:active {
  background: #f5f5f7;
}

.task-check {
  margin-right: 20rpx;
  padding: 8rpx;
}

.task-check-circle {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 3rpx solid #c7c7cc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #ffffff;
}

.task-check-circle.done {
  background: #007aff;
  border-color: #007aff;
}

.task-content {
  flex: 1;
  min-width: 0;
}

.task-title {
  font-size: 32rpx;
  color: #111111;
  margin-bottom: 8rpx;
  word-wrap: break-word;
}

.task-title.done {
  color: #999999;
  text-decoration: line-through;
}

.task-date {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 6rpx;
}

.task-date.done {
  color: #999999;
}

.task-note {
  font-size: 28rpx;
  color: #666666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.add-button-container {
  padding: 24rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #f5f5f7;
}
