/* 全局主题色 - 小纸条温柔风格 */
page {
  --primary: #6BA3C7;
  --primary-light: #F0F7FF;
  --bg: #E8F4FD;
  --gray: #F5F5F5;
  --text: #333333;
  --text-light: #7A8B9A;
  --shadow: 0 8rpx 48rpx rgba(107, 163, 199, 0.15);
  
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

.container {
  padding: 32rpx;
  min-height: 100vh;
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  box-shadow: var(--shadow);
}

.btn-primary {
  background: var(--primary);
  color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  font-size: 32rpx;
  border: none;
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 24rpx;
  padding: 22rpx 32rpx;
  font-size: 32rpx;
}

.btn-secondary {
  background: var(--gray);
  color: var(--text);
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  font-size: 32rpx;
  border: none;
}

.empty-state {
  text-align: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-light);
}
